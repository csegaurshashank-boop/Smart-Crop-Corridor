MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/crop_corridor
DATABASE_NAME=crop_corridor
SECRET_KEY=your_super_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Copernicus Data Space Ecosystem (CDSE) ────────────────────────────────────
# FREE real Sentinel-2 NDVI — no credit card needed
# Register at: https://dataspace.copernicus.eu
# Dashboard → User Settings → OAuth Clients → Create New Client → copy below
CDSE_CLIENT_ID=your_client_id_here
CDSE_CLIENT_SECRET=your_client_secret_here

# ── Optional (not required, system works without these) ──────────────────────
# Open-Meteo (weather)  → FREE, no key needed
# SoilGrids ISRIC (soil)→ FREE, no key needed
SENTINEL_HUB_TOKEN=
OPENWEATHER_API_KEY=