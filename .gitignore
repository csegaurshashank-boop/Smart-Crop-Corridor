# ============================================================
#  Crop Corridor System — .gitignore
# ============================================================

# ─── Environment & Secrets ───────────────────────────────────
.env
.env.local
.env.*.local
.env.production

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.pyo
*.pyd

# Virtual Environments
venv/
env/
ENV/
.venv/
.env/
virtualenv/

# PyTest / Coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Jupyter Notebooks
.ipynb_checkpoints/

# ─── ML Models & Large Files ─────────────────────────────────
# YOLO & trained model weights (large binaries — use Git LFS or host externally)
*.pt
*.pth
*.weights
*.onnx
*.pkl
*.h5
*.hdf5
*.pb

# Dataset / training artifacts
datasets/
data/raw/
data/processed/
runs/
wandb/

# ─── Node / Frontend (crop-frontend) ─────────────────────────
crop-frontend/node_modules/
crop-frontend/dist/
crop-frontend/.cache/
crop-frontend/.parcel-cache/

# npm / yarn / pnpm lockfiles (keep package-lock.json if you want reproducible installs)
# Uncomment the line below only if you do NOT want to commit the lockfile
# crop-frontend/package-lock.json

# Vite
crop-frontend/.vite/

# ─── IDEs & Editors ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS Files ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
